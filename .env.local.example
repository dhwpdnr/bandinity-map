# 카카오 지도 JavaScript API 키
# https://developers.kakao.com/ 에서 앱 생성 후 키 발급
NEXT_PUBLIC_KAKAO_APP_KEY=your_kakao_javascript_key

# 카카오 로그인 (OAuth)
# REST API 키(클라이언트 ID), 선택적 Client Secret, 등록된 Redirect URI
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:3000/api/auth/kakao/callback

# Firebase (Firestore)
# https://console.firebase.google.com/ 프로젝트 설정에서 확인
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Cloudinary (이미지 업로드)
# https://cloudinary.com/ 가입 후 Dashboard에서 Cloud Name 확인
# Settings > Upload > Upload presets 에서 unsigned preset 생성
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# 관리자 로그인
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
USER_SESSION_SECRET=

# Firebase Admin SDK (관리자 승인/수정용)
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
