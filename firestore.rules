rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /venues/{venueId} {
      allow read: if true;
      allow create: if isValidVenue(request.resource.data);
      allow update: if isValidVenueUpdate(request.resource.data);
      allow delete: if true;

      match /reviews/{reviewId} {
        allow read, write: if true;
      }
    }

    match /placeSubmissions/{submissionId} {
      allow read: if false;
      allow create: if true;
      allow update, delete: if false;
    }
  }

  function isValidVenue(data) {
    return data.keys().hasAll(['name', 'address', 'lat', 'lng', 'region'])
      && data.name is string && data.name.size() > 0 && data.name.size() <= 100
      && data.address is string && data.address.size() > 0
      && data.lat is number && data.lat >= -90 && data.lat <= 90
      && data.lng is number && data.lng >= -180 && data.lng <= 180
      && data.region is string && data.region.size() > 0;
  }

  function isValidVenueUpdate(data) {
    return (!('name' in data) || (data.name is string && data.name.size() > 0 && data.name.size() <= 100))
      && (!('lat' in data) || (data.lat is number && data.lat >= -90 && data.lat <= 90))
      && (!('lng' in data) || (data.lng is number && data.lng >= -180 && data.lng <= 180));
  }
}
